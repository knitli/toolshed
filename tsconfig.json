{
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ESNext"],
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["./**/*.ts", "./**/*.tsx", "./**/*.mts", "./**/*.cts"],
  "exclude": ["node_modules", "dist"]
}
