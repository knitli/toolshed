{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "scope-enum": [
      2,
      "always",
      [
        "ctx",
        "strip-ansi",
        "codeweaver",
        "marketplace",
        "mkt",
        "market",
        "mp",
        "cw",
        "sa",
        "ansi"
      ]
    ],
    "scope-empty": [
      2,
      "never"
    ]
  }
}
