{
  "name": "@knitli/plugin-strip-ansi",
  "version": "1.1.0",
  "private": false,
  "description": "Sanitizes ANSI escape sequences from tool output and detects terminal-based prompt injection attacks (CVE-tagged). Full protection for MCP tools via output replacement; partial protection for built-in tools via context injection.",
  "author": {
    "name": "Knitli Inc.",
    "email": "hello@knitli.com"
  },
  "license": "MIT OR Apache-2.0",
  "homepage": "https://knitli.com",
  "keywords": [
    "ansi",
    "sanitize",
    "security",
    "mcp",
    "prompt-injection",
    "hygiene",
    "context"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/knitli/toolshed",
    "directory": "plugins/strip-ansi"
  },
  "release": {
    "branches": [
      "main"
    ],
    "tagFormat": "@knitli/strip-ansi-v${version}",
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits",
          "releaseRules": [
            {
              "breaking": true,
              "scope": "strip-ansi",
              "release": "major"
            },
            {
              "scope": "strip-ansi",
              "type": "feat",
              "release": "minor"
            },
            {
              "scope": "strip-ansi",
              "type": "fix",
              "release": "patch"
            },
            {
              "scope": "strip-ansi",
              "type": "perf",
              "release": "patch"
            },
            {
              "breaking": true,
              "scope": "sa",
              "release": "major"
            },
            {
              "scope": "sa",
              "type": "feat",
              "release": "minor"
            },
            {
              "scope": "sa",
              "type": "fix",
              "release": "patch"
            },
            {
              "scope": "sa",
              "type": "perf",
              "release": "patch"
            },
            {
              "breaking": true,
              "scope": "ansi",
              "release": "major"
            },
            {
              "scope": "ansi",
              "type": "feat",
              "release": "minor"
            },
            {
              "scope": "ansi",
              "type": "fix",
              "release": "patch"
            },
            {
              "scope": "ansi",
              "type": "perf",
              "release": "patch"
            },
            {
              "release": false
            }
          ]
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}
