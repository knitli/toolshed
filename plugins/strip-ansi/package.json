{
  "name": "@knitli/strip-ansi",
  "version": "0.1.0",
  "private": true,
  "description": "Prevents ANSI escape sequences from polluting agent context, commits, PRs, and file edits. Injects NO_COLOR into Bash tool calls and sanitizes any residual escapes from output.",
  "author": {
    "name": "Knitli Inc.",
    "email": "hello@knitli.com"
  },
  "license": "MIT",
  "homepage": "https://knitli.com",
  "keywords": [
    "ansi",
    "sanitize",
    "hygiene",
    "context",
    "no-color"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/knitli/toolshed"
  },
  "release": {
    "extends": "semantic-release-monorepo",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/git",
      "@semantic-release/github"
    ]
  }
}
